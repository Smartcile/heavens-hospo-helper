generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  STAFF
}

enum CompletionType {
  TICK
  TICK_NOTE
  TICK_PHOTO
}

enum ScheduleType {
  DAILY
  WEEKLY
  CUSTOM
}

enum TimeOffStatus {
  PENDING
  APPROVED
  DECLINED
}

enum NoticePriority {
  INFO
  IMPORTANT
  URGENT
}

enum CalendarSource {
  GOOGLE
  ICAL
  MANUAL
}

// A knowledge resource's type. TRAINING is a sign-off-able guide; the rest are
// reference material that bundles alongside tasks in a section.
enum ResourceKind {
  TRAINING
  SOP
  FAQ
  HOWTO
}

enum FollowUpKind {
  MISSED     // a due task wasn't completed
  UNTRAINED  // a task was completed by someone without the required training
  INCORRECT  // a manager flagged work as not done correctly
}

enum FollowUpStatus {
  OPEN
  RESOLVED
}

model Venue {
  id         String    @id @default(uuid())
  name       String
  address    String?
  timezone   String    @default("Pacific/Auckland")
  isActive   Boolean   @default(true)
  // External embeds (pasteable links shown live in the app)
  loadedRosterUrl        String?
  googleCalendarUrl      String?   // also imported into the planner via its derived iCal feed
  icalFeedUrl            String?   // any .ics subscribe link (e.g. a Loaded/roster calendar feed) — imported
  externalRefreshMinutes Int     @default(0) // 0 = manual refresh only
  lastExternalSyncAt     DateTime? // last successful calendar import
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  departments Department[]
  staff       Staff[]
  tasks       Task[]
  qrCodes     QRCode[]
  budgetPeriods BudgetPeriod[]
  trainingModules TrainingModule[]
  taskTemplates TaskTemplate[]
  shiftNotes  ShiftNote[]
  shifts      Shift[]
  timeOffRequests TimeOffRequest[]
  notices     Notice[]
  calendarEvents CalendarEvent[]
  sections    Section[]
  followUps   FollowUp[]
}

model Department {
  id        String    @id @default(uuid())
  name      String
  venueId   String
  colour    String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  venue  Venue   @relation(fields: [venueId], references: [id])
  staff  Staff[]
  tasks  Task[]
  qrCodes QRCode[]
  trainingModules TrainingModule[]
  shifts Shift[]
  notices Notice[]
  sections Section[]
}

model Staff {
  id              String    @id @default(uuid())
  firstName       String
  lastName        String
  pin             String?   // worker QR + PIN login (bcrypt). Optional: pure admins may have none.
  email           String?   @unique // admin/manager web login + cross-system match key
  password        String?   // admin/manager web login (bcrypt)
  role            Role      @default(STAFF)
  venueId         String
  departmentId    String?
  profilePhotoUrl String?
  isActive        Boolean   @default(true)
  // --- External system links (one profile, many systems). Sync is "coming soon";
  //     these IDs let an admin link a person across systems now. ---
  swiftPosId      String?   // SwiftPOS staff id
  myHrId          String?   // MyHR id
  loadedReportsId String?   // LoadedReports id
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  venue            Venue            @relation(fields: [venueId], references: [id])
  department       Department?      @relation(fields: [departmentId], references: [id])
  taskCompletions  TaskCompletion[]
  trainingAssignments TrainingAssignment[]
  trainingCompletions TrainingCompletion[]
  shiftNotes       ShiftNote[]
  shifts           Shift[]
  timeOffRequests  TimeOffRequest[]
  noticeAcks       NoticeAck[]
  sections         StaffSection[]
  followUps        FollowUp[]
}

model Task {
  id                String       @id @default(uuid())
  title             String
  description       String?
  venueId           String
  departmentId      String?
  sectionId         String?
  assignedToStaffId String?
  completionType    CompletionType @default(TICK)
  scheduleType      ScheduleType   @default(DAILY)
  scheduleDays      Int[]
  customCron        String?
  isActive          Boolean      @default(true)
  sortOrder         Int          @default(0)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  deletedAt         DateTime?

  venue            Venue            @relation(fields: [venueId], references: [id])
  department       Department?      @relation(fields: [departmentId], references: [id])
  section          Section?         @relation(fields: [sectionId], references: [id])
  taskCompletions  TaskCompletion[]
  trainingSteps    TrainingStep[]   @relation("StepLinkedTask")
  trainingModules  TrainingModule[] @relation("ModuleLinkedTask")
  requiredTraining TaskRequiredTraining[]
  followUps        FollowUp[]
}

model TaskCompletion {
  id            String   @id @default(uuid())
  taskId        String
  staffId       String
  completedAt   DateTime @default(now())
  note          String?
  photoUrl      String?
  scheduledDate DateTime @db.Date
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  task  Task  @relation(fields: [taskId], references: [id])
  staff Staff @relation(fields: [staffId], references: [id])
}

model QRCode {
  id           String    @id @default(uuid())
  venueId      String
  departmentId String?
  label        String
  token        String    @unique @default(uuid())
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  venue      Venue       @relation(fields: [venueId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])
}

// --- TASK TEMPLATES (Phase 2) ---

model TaskTemplate {
  id          String    @id @default(uuid())
  name        String              // ALL CAPS, e.g. "BAR OPEN"
  description String?
  category    String?             // grouping hint, e.g. "BAR", "KITCHEN", "FOH", "GENERAL"
  isBuiltIn   Boolean   @default(false) // seeded curated templates (not editable/deletable)
  venueId     String?             // null = global/shared; else scoped to one venue
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  venue Venue?             @relation(fields: [venueId], references: [id])
  items TaskTemplateItem[]
}

model TaskTemplateItem {
  id             String         @id @default(uuid())
  templateId     String
  title          String         // ALL CAPS
  description    String?
  completionType CompletionType @default(TICK)
  scheduleType   ScheduleType   @default(DAILY)
  scheduleDays   Int[]
  sortOrder      Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  template TaskTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

// --- TRAINING (Phase 3) ---

model TrainingModule {
  id              String    @id @default(uuid())
  title           String              // ALL CAPS
  description     String?
  category        String?             // grouping, e.g. "BAR", "FOOD SAFETY"
  venueId         String
  departmentId    String?             // if set, auto-applies to all staff in this department
  linkedTaskId    String?             // if set, this guide is the how-to for a task
  kind            ResourceKind @default(TRAINING) // TRAINING (sign-off-able) | SOP | FAQ | HOWTO (reference)
  requiresSignOff Boolean   @default(false) // true = a manager must sign off; false = staff self-complete
  isOnboarding    Boolean   @default(false) // part of the onboarding checklist (applies to all staff)
  onboardingOrder Int       @default(0)
  isActive        Boolean   @default(true)
  sortOrder       Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  venue       Venue                @relation(fields: [venueId], references: [id])
  department  Department?          @relation(fields: [departmentId], references: [id])
  linkedTask  Task?                @relation("ModuleLinkedTask", fields: [linkedTaskId], references: [id])
  steps       TrainingStep[]
  assignments TrainingAssignment[]
  completions TrainingCompletion[]
  resourceSections ResourceSection[]
  requiredByTasks  TaskRequiredTraining[]
  linksFrom   ResourceLink[] @relation("ResourceLinkFrom")
  linksTo     ResourceLink[] @relation("ResourceLinkTo")
  followUps   FollowUp[]
}

model TrainingStep {
  id            String    @id @default(uuid())
  moduleId      String
  order         Int
  title         String?
  content       String
  imageUrl      String?           // uploaded photo
  videoUrl      String?           // external video link (YouTube/Vimeo/etc)
  linkedTaskId  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  module     TrainingModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  linkedTask Task?          @relation("StepLinkedTask", fields: [linkedTaskId], references: [id])
}

// Individual assignment of a module to a person (upskill / area to work on).
// Onboarding + department applicability is computed, not stored here.
model TrainingAssignment {
  id           String    @id @default(uuid())
  moduleId     String
  staffId      String
  assignedById String?            // manager who assigned (Staff id, no relation)
  reason       String?            // e.g. "UPSKILL", "AREA TO WORK ON"
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  module TrainingModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  staff  Staff          @relation(fields: [staffId], references: [id])

  @@unique([moduleId, staffId])
}

model TrainingCompletion {
  id            String   @id @default(uuid())
  moduleId      String
  staffId       String
  completedAt   DateTime @default(now())
  selfCompleted Boolean  @default(false) // true = staff ticked it; false = manager sign-off
  signedOffById String?            // manager who signed off (Staff id, no relation)
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  module TrainingModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  staff  Staff          @relation(fields: [staffId], references: [id])

  @@unique([moduleId, staffId])
}

// --- NOTICE BOARD ---

model Notice {
  id           String         @id @default(uuid())
  venueId      String
  departmentId String?        // null = whole venue
  title        String
  body         String
  priority     NoticePriority @default(INFO)
  pinned       Boolean        @default(false)
  requiresAck  Boolean        @default(false)
  startsAt     DateTime?      // active-window start (null = immediately)
  endsAt       DateTime?      // active-window end (null = no expiry)
  isActive     Boolean        @default(true)
  createdById  String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?

  venue      Venue       @relation(fields: [venueId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])
  acks       NoticeAck[]
}

model NoticeAck {
  id       String   @id @default(uuid())
  noticeId String
  staffId  String
  ackedAt  DateTime @default(now())

  notice Notice @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  staff  Staff  @relation(fields: [staffId], references: [id])

  @@unique([noticeId, staffId])
}

// --- CALENDAR: roster + time off ---

// A rostered shift for a person on a date. Times are local "HH:mm" strings —
// a shift is "this calendar day, from start to end in venue-local time".
model Shift {
  id           String    @id @default(uuid())
  staffId      String
  venueId      String
  departmentId String?
  date         DateTime  @db.Date
  startTime    String    // "09:00"
  endTime      String    // "17:00"
  note         String?
  createdById  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  staff      Staff       @relation(fields: [staffId], references: [id])
  venue      Venue       @relation(fields: [venueId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])

  @@index([venueId, date])
  @@index([staffId, date])
}

// An event imported from an external calendar feed (Google Calendar / any iCal).
// Keyed by (venueId, source, uid) so re-syncing UPDATES the same row instead of
// duplicating; events that vanish from the feed are soft-deleted on next sync.
model CalendarEvent {
  id           String         @id @default(uuid())
  venueId      String
  source       CalendarSource @default(ICAL)
  uid          String         // stable id from the feed (per-occurrence for recurring)
  title        String
  description  String?
  location     String?
  startsAt     DateTime
  endsAt       DateTime?
  allDay       Boolean        @default(false)
  lastSyncedAt DateTime       @default(now())
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?

  venue Venue @relation(fields: [venueId], references: [id])

  @@unique([venueId, source, uid])
  @@index([venueId, startsAt])
}

model TimeOffRequest {
  id           String        @id @default(uuid())
  staffId      String
  venueId      String
  startDate    DateTime      @db.Date
  endDate      DateTime      @db.Date
  reason       String?
  status       TimeOffStatus @default(PENDING)
  reviewedById String?
  reviewedAt   DateTime?
  reviewNote   String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  staff Staff @relation(fields: [staffId], references: [id])
  venue Venue @relation(fields: [venueId], references: [id])

  @@index([venueId, status])
  @@index([staffId])
}

// Manager end-of-day notes about a person for a given shift date. An
// "AREA TO WORK ON" can be linked to a training module assigned to address it.
model ShiftNote {
  id             String    @id @default(uuid())
  staffId        String
  venueId        String
  authorId       String?            // manager who wrote it (Staff id, no relation)
  shiftDate      DateTime  @db.Date
  category       String    @default("AREA TO WORK ON") // AREA TO WORK ON | PRAISE | INCIDENT | GENERAL
  content        String
  linkedModuleId String?            // training module assigned to address this
  resolvedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  staff Staff @relation(fields: [staffId], references: [id])
  venue Venue @relation(fields: [venueId], references: [id])
}

model BudgetPeriod {
  id           String    @id @default(uuid())
  venueId      String
  month        Int       // 1-12
  year         Int
  totalBudget  Float
  workingDays  Int       @default(0) // count of working days (derived on save)
  label        String?   // optional, e.g. "WAGES", "FOOD COST"
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  venue       Venue                @relation(fields: [venueId], references: [id])
  allocations BudgetDayAllocation[]

  @@unique([venueId, year, month])
}

model BudgetDayAllocation {
  id             String    @id @default(uuid())
  budgetPeriodId String
  date           DateTime  @db.Date
  amount         Float     @default(0)
  isWorkingDay   Boolean   @default(true)
  note           String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  budgetPeriod BudgetPeriod @relation(fields: [budgetPeriodId], references: [id], onDelete: Cascade)

  @@unique([budgetPeriodId, date])
}

// --- SECTION ECOSYSTEM (Phase A–D) ---

// A station within a department, e.g. Bar / Coffee / Cabinet under "Front of house".
// Venue → Department → Section. Tasks and resources can attach here.
model Section {
  id           String    @id @default(uuid())
  name         String              // ALL CAPS
  venueId      String              // denormalised from department for scoping
  departmentId String
  colour       String?
  sortOrder    Int       @default(0)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  venue      Venue      @relation(fields: [venueId], references: [id])
  department Department @relation(fields: [departmentId], references: [id])
  tasks      Task[]
  staff      StaffSection[]
  resources  ResourceSection[]

  @@index([venueId])
  @@index([departmentId])
}

// Staff ⇄ Section (a person can work many sections).
model StaffSection {
  id        String   @id @default(uuid())
  staffId   String
  sectionId String
  createdAt DateTime @default(now())

  staff   Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([staffId, sectionId])
}

// Resource ⇄ Section (a resource can be shared across many sections).
model ResourceSection {
  id        String   @id @default(uuid())
  moduleId  String
  sectionId String
  createdAt DateTime @default(now())

  module  TrainingModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  section Section        @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([moduleId, sectionId])
}

// Resource ⇄ Resource cross-reference (a task's SOP → its training → its FAQ).
model ResourceLink {
  id           String   @id @default(uuid())
  fromModuleId String
  toModuleId   String
  createdAt    DateTime @default(now())

  fromModule TrainingModule @relation("ResourceLinkFrom", fields: [fromModuleId], references: [id], onDelete: Cascade)
  toModule   TrainingModule @relation("ResourceLinkTo", fields: [toModuleId], references: [id], onDelete: Cascade)

  @@unique([fromModuleId, toModuleId])
}

// Task ⇄ Training "requires" — the competency a person needs to do this task.
model TaskRequiredTraining {
  id        String   @id @default(uuid())
  taskId    String
  moduleId  String
  createdAt DateTime @default(now())

  task   Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  module TrainingModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([taskId, moduleId])
}

// A follow-up raised by the trigger engine for a manager to action.
model FollowUp {
  id           String         @id @default(uuid())
  venueId      String
  staffId      String
  taskId       String?
  moduleId     String?        // training to do / that was missing
  kind         FollowUpKind
  status       FollowUpStatus @default(OPEN)
  detail       String?
  dueDate      DateTime?      @db.Date // the date the issue relates to (for MISSED)
  resolvedById String?
  resolvedAt   DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  venue  Venue           @relation(fields: [venueId], references: [id])
  staff  Staff           @relation(fields: [staffId], references: [id])
  task   Task?           @relation(fields: [taskId], references: [id])
  module TrainingModule? @relation(fields: [moduleId], references: [id])

  @@unique([venueId, staffId, kind, taskId, dueDate])
  @@index([venueId, status])
}
