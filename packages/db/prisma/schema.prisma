generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  STAFF
}

enum CompletionType {
  TICK
  TICK_NOTE
  TICK_PHOTO
}

enum ScheduleType {
  DAILY
  WEEKLY
  MONTHLY
  CUSTOM
}

enum TimeOffStatus {
  PENDING
  APPROVED
  DECLINED
}

enum NoticePriority {
  INFO
  IMPORTANT
  URGENT
}

enum CalendarSource {
  GOOGLE
  ICAL
  MANUAL
}

// A knowledge resource's type. TRAINING is a sign-off-able guide; the rest are
// reference material that bundles alongside tasks in a section.
enum ResourceKind {
  TRAINING
  SOP
  FAQ
  HOWTO
}

enum FollowUpKind {
  MISSED     // a due task wasn't completed
  UNTRAINED  // a task was completed by someone without the required training
  INCORRECT  // a manager flagged work as not done correctly
}

enum FollowUpStatus {
  OPEN
  RESOLVED
}

model Venue {
  id         String    @id @default(uuid())
  name       String
  address    String?
  timezone   String    @default("Pacific/Auckland")
  isActive   Boolean   @default(true)
  // External embeds (pasteable links shown live in the app)
  loadedRosterUrl        String?
  googleCalendarUrl      String?   // also imported into the planner via its derived iCal feed
  icalFeedUrl            String?   // any .ics subscribe link (e.g. a Loaded/roster calendar feed) — imported
  externalRefreshMinutes Int     @default(0) // 0 = manual refresh only
  lastExternalSyncAt     DateTime? // last successful calendar import
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  departments Department[]
  staff       Staff[]
  tasks       Task[]
  qrCodes     QRCode[]
  budgetPeriods BudgetPeriod[]
  trainingModules TrainingModule[]
  taskTemplates TaskTemplate[]
  shiftNotes  ShiftNote[]
  shifts      Shift[]
  timeOffRequests TimeOffRequest[]
  notices     Notice[]
  calendarEvents CalendarEvent[]
  sections    Section[]
  followUps   FollowUp[]
  checklists  Checklist[]
  floorPlans          FloorPlan[]
  inventoryCategories InventoryCategory[]
  inventoryItems      InventoryItem[]
  paletteDefaults     PaletteDefault[]
  stocktakeRecords    StocktakeRecord[]
}

model Department {
  id        String    @id @default(uuid())
  name      String
  venueId   String
  colour    String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  venue  Venue   @relation(fields: [venueId], references: [id])
  staff  Staff[]
  tasks  Task[]
  trainingModules TrainingModule[]
  shifts Shift[]
  notices Notice[]
  sections Section[]
  checklists Checklist[]
  budgetCategories BudgetCategory[]
}

model Staff {
  id              String    @id @default(uuid())
  firstName       String
  lastName        String
  pin             String?   // worker QR + PIN login (bcrypt). Optional: pure admins may have none.
  email           String?   @unique // admin/manager web login + cross-system match key
  password        String?   // admin/manager web login (bcrypt)
  role            Role      @default(STAFF)
  venueId         String
  departmentId    String?
  profilePhotoUrl String?
  isActive        Boolean   @default(true)
  // --- External system links (one profile, many systems). Sync is "coming soon";
  //     these IDs let an admin link a person across systems now. ---
  swiftPosId      String?   // SwiftPOS staff id
  myHrId          String?   // MyHR id
  loadedReportsId String?   // LoadedReports id
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  venue            Venue            @relation(fields: [venueId], references: [id])
  department       Department?      @relation(fields: [departmentId], references: [id])
  taskCompletions  TaskCompletion[]
  trainingAssignments TrainingAssignment[]
  trainingCompletions TrainingCompletion[]
  shiftNotes       ShiftNote[]
  shifts           Shift[]
  timeOffRequests  TimeOffRequest[]
  noticeAcks       NoticeAck[]
  sections             StaffSection[]
  followUps            FollowUp[]
  stocktakeCompletions StocktakeRecord[] @relation("stocktakeCompletedBy")
  stocktakeAssignments StocktakeRecord[] @relation("stocktakeAssignedTo")
}

model Task {
  id                String       @id @default(uuid())
  title             String
  description       String?
  venueId           String
  departmentId      String?
  sectionId         String?
  assignedToStaffId String?
  completionType    CompletionType @default(TICK)
  scheduleType      ScheduleType   @default(DAILY)
  scheduleDays      Int[]
  customCron        String?
  intervalMonths    Int          @default(1)  // MONTHLY: run every N months (anchored on createdAt month)
  monthlyOption     String?      // MONTHLY: FIRST_DAY | LAST_DAY | FIFTEENTH | FIRST_WEEKDAY | LAST_WEEKDAY | FIRST_MONDAY | LAST_FRIDAY | SPECIFIC_DAY
  monthlyDay        Int?         // MONTHLY + SPECIFIC_DAY: day of month (1-31, clamped)
  isActive          Boolean      @default(true)
  sortOrder         Int          @default(0)
  version           Int          @default(1) // bumped on a "significant change" (drives re-train)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  deletedAt         DateTime?

  venue            Venue            @relation(fields: [venueId], references: [id])
  department       Department?      @relation(fields: [departmentId], references: [id])
  section          Section?         @relation(fields: [sectionId], references: [id])
  taskCompletions  TaskCompletion[]
  trainingSteps    TrainingStep[]   @relation("StepLinkedTask")
  trainingModules  TrainingModule[] @relation("ModuleLinkedTask")
  requiredTraining TaskRequiredTraining[]
  checklistLinks   ChecklistTask[]
  followUps        FollowUp[]
}

model TaskCompletion {
  id            String   @id @default(uuid())
  taskId        String
  staffId       String
  completedAt   DateTime @default(now())
  note          String?
  photoUrl      String?
  scheduledDate DateTime @db.Date
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  task  Task  @relation(fields: [taskId], references: [id])
  staff Staff @relation(fields: [staffId], references: [id])
}

model QRCode {
  id        String    @id @default(uuid())
  venueId   String
  label     String
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  venue Venue @relation(fields: [venueId], references: [id])
}

// --- TASK TEMPLATES (Phase 2) ---

model TaskTemplate {
  id          String    @id @default(uuid())
  name        String              // ALL CAPS, e.g. "BAR OPEN"
  description String?
  category    String?             // grouping hint, e.g. "BAR", "KITCHEN", "FOH", "GENERAL"
  isBuiltIn   Boolean   @default(false) // seeded curated templates (not editable/deletable)
  venueId     String?             // null = global/shared; else scoped to one venue
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  venue Venue?             @relation(fields: [venueId], references: [id])
  items TaskTemplateItem[]
}

model TaskTemplateItem {
  id             String         @id @default(uuid())
  templateId     String
  title          String         // ALL CAPS
  description    String?
  completionType CompletionType @default(TICK)
  scheduleType   ScheduleType   @default(DAILY)
  scheduleDays   Int[]
  sortOrder      Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  template TaskTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

// --- TRAINING (Phase 3) ---

model TrainingModule {
  id              String    @id @default(uuid())
  title           String              // ALL CAPS
  description     String?
  category        String?             // grouping, e.g. "BAR", "FOOD SAFETY"
  venueId         String
  departmentId    String?             // if set, auto-applies to all staff in this department
  linkedTaskId    String?             // if set, this guide is the how-to for a task
  kind            ResourceKind @default(TRAINING) // TRAINING (sign-off-able) | SOP | FAQ | HOWTO (reference)
  version         Int       @default(1) // bumped on a "significant change" (drives re-train)
  requiresSignOff Boolean   @default(false) // true = a manager must sign off; false = staff self-complete
  isOnboarding    Boolean   @default(false) // part of the onboarding checklist (applies to all staff)
  onboardingOrder Int       @default(0)
  isActive        Boolean   @default(true)
  sortOrder       Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  venue       Venue                @relation(fields: [venueId], references: [id])
  department  Department?          @relation(fields: [departmentId], references: [id])
  linkedTask  Task?                @relation("ModuleLinkedTask", fields: [linkedTaskId], references: [id])
  steps       TrainingStep[]
  assignments TrainingAssignment[]
  completions TrainingCompletion[]
  resourceSections ResourceSection[]
  requiredByTasks  TaskRequiredTraining[]
  linksFrom   ResourceLink[] @relation("ResourceLinkFrom")
  linksTo     ResourceLink[] @relation("ResourceLinkTo")
  followUps   FollowUp[]
}

model TrainingStep {
  id            String    @id @default(uuid())
  moduleId      String
  order         Int
  title         String?
  content       String
  imageUrl      String?           // uploaded photo
  videoUrl      String?           // external video link (YouTube/Vimeo/etc)
  linkedTaskId  String?
  linkedChecklistId String?       // embed a whole checklist into this step (tick off in person)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  module          TrainingModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  linkedTask      Task?          @relation("StepLinkedTask", fields: [linkedTaskId], references: [id])
  linkedChecklist Checklist?     @relation(fields: [linkedChecklistId], references: [id])
}

// Individual assignment of a module to a person (upskill / area to work on).
// Onboarding + department applicability is computed, not stored here.
model TrainingAssignment {
  id           String    @id @default(uuid())
  moduleId     String
  staffId      String
  assignedById String?            // manager who assigned (Staff id, no relation)
  reason       String?            // e.g. "UPSKILL", "AREA TO WORK ON"
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  module TrainingModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  staff  Staff          @relation(fields: [staffId], references: [id])

  @@unique([moduleId, staffId])
}

model TrainingCompletion {
  id            String   @id @default(uuid())
  moduleId      String
  staffId       String
  completedAt   DateTime @default(now())
  selfCompleted Boolean  @default(false) // true = staff ticked it; false = manager sign-off
  signedOffById String?            // manager who signed off (Staff id, no relation)
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  module TrainingModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  staff  Staff          @relation(fields: [staffId], references: [id])

  @@unique([moduleId, staffId])
}

// --- NOTICE BOARD ---

model Notice {
  id           String         @id @default(uuid())
  venueId      String
  departmentId String?        // null = whole venue
  title        String
  body         String
  priority     NoticePriority @default(INFO)
  pinned       Boolean        @default(false)
  requiresAck  Boolean        @default(false)
  startsAt     DateTime?      // active-window start (null = immediately)
  endsAt       DateTime?      // active-window end (null = no expiry)
  isActive     Boolean        @default(true)
  createdById  String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?

  venue      Venue       @relation(fields: [venueId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])
  acks       NoticeAck[]
}

model NoticeAck {
  id       String   @id @default(uuid())
  noticeId String
  staffId  String
  ackedAt  DateTime @default(now())

  notice Notice @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  staff  Staff  @relation(fields: [staffId], references: [id])

  @@unique([noticeId, staffId])
}

// --- CALENDAR: roster + time off ---

// A rostered shift for a person on a date. Times are local "HH:mm" strings —
// a shift is "this calendar day, from start to end in venue-local time".
model Shift {
  id           String    @id @default(uuid())
  staffId      String
  venueId      String
  departmentId String?
  date         DateTime  @db.Date
  startTime    String    // "09:00"
  endTime      String    // "17:00"
  note         String?
  createdById  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  staff      Staff       @relation(fields: [staffId], references: [id])
  venue      Venue       @relation(fields: [venueId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])

  @@index([venueId, date])
  @@index([staffId, date])
}

// An event imported from an external calendar feed (Google Calendar / any iCal).
// Keyed by (venueId, source, uid) so re-syncing UPDATES the same row instead of
// duplicating; events that vanish from the feed are soft-deleted on next sync.
model CalendarEvent {
  id           String         @id @default(uuid())
  venueId      String
  source       CalendarSource @default(ICAL)
  uid          String         // stable id from the feed (per-occurrence for recurring)
  title        String
  description  String?
  location     String?
  startsAt     DateTime
  endsAt       DateTime?
  allDay         Boolean   @default(false)
  floorPlanSlug  String?   // links event to a specific floor plan layout
  floorPlanName  String?   // display name for the banner
  lastSyncedAt   DateTime  @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  venue Venue @relation(fields: [venueId], references: [id])

  @@unique([venueId, source, uid])
  @@index([venueId, startsAt])
}

model TimeOffRequest {
  id           String        @id @default(uuid())
  staffId      String
  venueId      String
  startDate    DateTime      @db.Date
  endDate      DateTime      @db.Date
  reason       String?
  status       TimeOffStatus @default(PENDING)
  reviewedById String?
  reviewedAt   DateTime?
  reviewNote   String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  staff Staff @relation(fields: [staffId], references: [id])
  venue Venue @relation(fields: [venueId], references: [id])

  @@index([venueId, status])
  @@index([staffId])
}

// Manager end-of-day notes about a person for a given shift date. An
// "AREA TO WORK ON" can be linked to a training module assigned to address it.
model ShiftNote {
  id             String    @id @default(uuid())
  staffId        String
  venueId        String
  authorId       String?            // manager who wrote it (Staff id, no relation)
  shiftDate      DateTime  @db.Date
  category       String    @default("AREA TO WORK ON") // AREA TO WORK ON | PRAISE | INCIDENT | GENERAL
  content        String
  linkedModuleId String?            // training module assigned to address this
  resolvedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  staff Staff @relation(fields: [staffId], references: [id])
  venue Venue @relation(fields: [venueId], references: [id])
}

model BudgetPeriod {
  id           String    @id @default(uuid())
  venueId      String
  year         Int
  month        Int       // 1-12
  totalBudget  Float
  dailyWeights Json?     // { mon, tue, wed, thu, fri, sat, sun } — each a number, sums to 100
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  venue      Venue            @relation(fields: [venueId], references: [id])
  categories BudgetCategory[]
  days       BudgetDay[]

  @@unique([venueId, year, month])
}

model BudgetCategory {
  id             String    @id @default(uuid())
  budgetPeriodId String
  departmentId   String?
  name           String    // ALL CAPS
  percentage     Float     // e.g. 30.5
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  period      BudgetPeriod          @relation(fields: [budgetPeriodId], references: [id], onDelete: Cascade)
  department  Department?           @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  allocations BudgetDayAllocation[]
}

model BudgetDay {
  id             String    @id @default(uuid())
  budgetPeriodId String
  date           DateTime  @db.Date
  isWorkingDay   Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  period      BudgetPeriod          @relation(fields: [budgetPeriodId], references: [id], onDelete: Cascade)
  allocations BudgetDayAllocation[]

  @@unique([budgetPeriodId, date])
}

model BudgetDayAllocation {
  id               String    @id @default(uuid())
  budgetDayId      String
  budgetCategoryId String
  amount           Float
  note             String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  day      BudgetDay      @relation(fields: [budgetDayId], references: [id], onDelete: Cascade)
  category BudgetCategory @relation(fields: [budgetCategoryId], references: [id], onDelete: Cascade)

  @@unique([budgetDayId, budgetCategoryId])
}

// --- CHECKLISTS (live task references — single source of truth) ---

// A named, ordered list of LIVE tasks (not copies). Editing a task updates it
// everywhere it appears. A task can belong to many checklists.
model Checklist {
  id           String    @id @default(uuid())
  name         String              // ALL CAPS
  description  String?
  venueId      String
  departmentId String?
  sectionId    String?
  appearFromTime String?           // "HH:mm" venue-local — list shows from this time; stays until all done
  sortOrder    Int       @default(0)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  venue      Venue       @relation(fields: [venueId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])
  section    Section?    @relation(fields: [sectionId], references: [id])
  tasks      ChecklistTask[]
  trainingSteps TrainingStep[]

  @@index([venueId])
}

model ChecklistTask {
  id          String   @id @default(uuid())
  checklistId String
  taskId      String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  checklist Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  task      Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([checklistId, taskId])
}

// --- SECTION ECOSYSTEM (Phase A–D) ---

// A station within a department, e.g. Bar / Coffee / Cabinet under "Front of house".
// Venue → Department → Section. Tasks and resources can attach here.
model Section {
  id           String    @id @default(uuid())
  name         String              // ALL CAPS
  venueId      String              // denormalised from department for scoping
  departmentId String
  colour       String?
  sortOrder    Int       @default(0)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  venue      Venue      @relation(fields: [venueId], references: [id])
  department Department @relation(fields: [departmentId], references: [id])
  tasks      Task[]
  staff      StaffSection[]
  resources  ResourceSection[]
  checklists Checklist[]
  floorPlanElements FloorPlanElement[]

  @@index([venueId])
  @@index([departmentId])
}

// Staff ⇄ Section (a person can work many sections).
model StaffSection {
  id        String   @id @default(uuid())
  staffId   String
  sectionId String
  createdAt DateTime @default(now())

  staff   Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([staffId, sectionId])
}

// Resource ⇄ Section (a resource can be shared across many sections).
model ResourceSection {
  id        String   @id @default(uuid())
  moduleId  String
  sectionId String
  createdAt DateTime @default(now())

  module  TrainingModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  section Section        @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([moduleId, sectionId])
}

// Resource ⇄ Resource cross-reference (a task's SOP → its training → its FAQ).
model ResourceLink {
  id           String   @id @default(uuid())
  fromModuleId String
  toModuleId   String
  createdAt    DateTime @default(now())

  fromModule TrainingModule @relation("ResourceLinkFrom", fields: [fromModuleId], references: [id], onDelete: Cascade)
  toModule   TrainingModule @relation("ResourceLinkTo", fields: [toModuleId], references: [id], onDelete: Cascade)

  @@unique([fromModuleId, toModuleId])
}

// Task ⇄ Training "requires" — the competency a person needs to do this task.
model TaskRequiredTraining {
  id        String   @id @default(uuid())
  taskId    String
  moduleId  String
  createdAt DateTime @default(now())

  task   Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  module TrainingModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([taskId, moduleId])
}

// A follow-up raised by the trigger engine for a manager to action.
model FollowUp {
  id           String         @id @default(uuid())
  venueId      String
  staffId      String
  taskId       String?
  moduleId     String?        // training to do / that was missing
  kind         FollowUpKind
  status       FollowUpStatus @default(OPEN)
  detail       String?
  dueDate      DateTime?      @db.Date // the date the issue relates to (for MISSED)
  resolvedById String?
  resolvedAt   DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  venue  Venue           @relation(fields: [venueId], references: [id])
  staff  Staff           @relation(fields: [staffId], references: [id])
  task   Task?           @relation(fields: [taskId], references: [id])
  module TrainingModule? @relation(fields: [moduleId], references: [id])

  @@unique([venueId, staffId, kind, taskId, dueDate])
  @@index([venueId, status])
}

// --- FLOOR PLANNER ---

enum ElementType {
  WALL
  DOOR
  WINDOW
  TABLE
  CHAIR
  COUNTER
  BAR
  BOOTH_BENCH
  KITCHEN_EQUIP
  SINK
  STORAGE
  ENTRY
  EXIT
  STAIRS
  TOILET
  PLANT
  OTHER
}

enum ElementShape {
  RECTANGLE
  CIRCLE
  POLYGON
}

model FloorPlan {
  id         String    @id @default(uuid())
  venueId    String
  name       String
  slug       String
  isDefault  Boolean   @default(false)
  roomWidth  Float     @default(2000) // real-world cm
  roomDepth  Float     @default(1500) // real-world cm
  gridUnit   Float     @default(50)   // snap grid in cm
  zones      Json?                     // section zone rectangles [{id,x,y,w,h,sectionId}]
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  venue    Venue              @relation(fields: [venueId], references: [id])
  elements FloorPlanElement[]

  @@unique([venueId, slug])
  @@index([venueId])
}

model FloorPlanElement {
  id          String       @id @default(uuid())
  floorPlanId String
  type        ElementType
  shape       ElementShape @default(RECTANGLE)
  label       String?
  labelVisible Boolean   @default(true)
  style       Json?                     // per-element style config (wallType, tableShape, etc.)
  // Position in real-world cm from room top-left
  x           Float
  y           Float
  width       Float        @default(80)  // for RECTANGLE (cm)
  depth       Float        @default(80)  // for RECTANGLE (cm)
  radius      Float?                    // for CIRCLE (cm)
  vertices    Json?                     // for POLYGON: [{x,y},...] relative to anchor
  rotation    Float        @default(0)
  // Appearance
  colour      String?
  fillColour  String?
  opacity     Float        @default(1)
  zIndex      Int          @default(0)
  // Business links
  sectionId   String?
  capacity    Int?
  chairCount  Int          @default(0)
  sortOrder   Int          @default(0)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  floorPlan       FloorPlan             @relation(fields: [floorPlanId], references: [id], onDelete: Cascade)
  section         Section?              @relation(fields: [sectionId], references: [id])
  inventoryItems ElementInventoryItem[]

  @@index([floorPlanId])
}

// --- INVENTORY & STOCKTAKE ---

enum StocktakeStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

model InventoryCategory {
  id        String   @id @default(uuid())
  venueId   String?
  name      String
  isBuiltIn Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  venue Venue?         @relation(fields: [venueId], references: [id])
  items InventoryItem[]

  @@unique([venueId, name])
}

model InventoryItem {
  id              String   @id @default(uuid())
  venueId         String
  categoryId      String
  name            String
  unit            String   @default("EA")
  defaultParLevel Int      @default(0)
  // Furniture template fields (only for FURNITURE category items)
  totalQty        Int      @default(0)  // physical items owned, drives availableQty
  furnitureType   String?  // "TABLE" | "CHAIR" | null
  elementWidth    Float?   // cm
  elementDepth    Float?   // cm
  elementShape    String?  // "RECTANGLE" | "CIRCLE"
  defaultColour   String?  // hex colour
  defaultChairCount Int    @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  venue     Venue                @relation(fields: [venueId], references: [id])
  category  InventoryCategory    @relation(fields: [categoryId], references: [id])
  elements  ElementInventoryItem[]
  stocktake StocktakeLineItem[]

  @@index([venueId])
  @@index([categoryId])
}

model ElementInventoryItem {
  id        String   @id @default(uuid())
  elementId String
  itemId    String
  quantity  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  element FloorPlanElement @relation(fields: [elementId], references: [id], onDelete: Cascade)
  item    InventoryItem    @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([elementId, itemId])
  @@index([elementId])
  @@index([itemId])
}

model StocktakeRecord {
  id              String        @id @default(uuid())
  venueId         String
  date            DateTime      @db.Date
  status          StocktakeStatus @default(PENDING)
  assignedRoleId  String?
  assignedStaffId String?
  notes           String?
  completedById   String?
  completedAt     DateTime?
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  venue         Venue              @relation(fields: [venueId], references: [id])
  completedBy   Staff?             @relation("stocktakeCompletedBy", fields: [completedById], references: [id])
  lineItems     StocktakeLineItem[]
  assignedStaff Staff?             @relation("stocktakeAssignedTo", fields: [assignedStaffId], references: [id])

  @@index([venueId])
  @@index([status])
  @@index([assignedStaffId])
}

model StocktakeLineItem {
  id               String   @id @default(uuid())
  recordId         String
  itemId           String
  countedQuantity  Int      @default(0)
  expectedQuantity Int      @default(0)
  variance         Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  record StocktakeRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  item   InventoryItem   @relation(fields: [itemId], references: [id])

  @@unique([recordId, itemId])
  @@index([recordId])
}

model PaletteDefault {
  id      String @id @default(uuid())
  venueId String
  type    String
  width   Float
  depth   Float
  colour  String? @default("#555")
  chairCount Int @default(0)

  venue Venue @relation(fields: [venueId], references: [id])

  @@unique([venueId, type])
  @@index([venueId])
}
