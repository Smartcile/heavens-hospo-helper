# ── Database ────────────────────────────────────────────────────────
DB_USER=hospo_ops_user
DB_PASSWORD=change_me_to_something_strong

# ── NextAuth (admin login) ───────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace_with_generated_secret
# MUST be the exact URL you open in the browser, INCLUDING the port.
# e.g. http://192.168.1.10:3000  (or https://hospo.yourdomain.com behind a proxy)
NEXTAUTH_URL=http://your-server-ip:3000

# ── App ─────────────────────────────────────────────────────────────
APP_NAME=HOSPO OPS
# Same as NEXTAUTH_URL — this is baked into the QR codes staff scan, so it
# must be reachable from their phones (a LAN IP or public domain, with port).
APP_URL=http://your-server-ip:3000
# Host port the app is published on. Container always listens on 3000 internally.
APP_PORT=3000

# ── Worker session ───────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
WORKER_SESSION_SECRET=replace_with_another_generated_secret
WORKER_SESSION_EXPIRY_MINUTES=15
