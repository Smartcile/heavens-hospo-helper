# ── Database ────────────────────────────────────────────────────────
DB_USER=hospo_ops_user
DB_PASSWORD=change_me_to_something_strong

# ── Secrets ──────────────────────────────────────────────────────────
# Generate each with: openssl rand -base64 32
NEXTAUTH_SECRET=replace_with_generated_secret

# ── App ─────────────────────────────────────────────────────────────
APP_NAME=HOSPO OPS
# The ONE public URL you reach the app at — drives admin login AND the QR codes
# staff scan, so it must be reachable from their devices. Include the port if
# it isn't 80/443.
#   LAN:               http://192.168.1.100:9008
#   Cloudflare Tunnel: https://hospo.yourdomain.com   (no port needed)
APP_URL=http://your-server-ip:9008
# Host port the app is published on. Container always listens on 3000 internally.
# Not needed if you reach the app only through a Cloudflare Tunnel.
APP_PORT=9008

# ── Worker session ───────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
WORKER_SESSION_SECRET=replace_with_another_generated_secret
WORKER_SESSION_EXPIRY_MINUTES=15
