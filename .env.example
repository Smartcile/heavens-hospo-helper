# Database
DB_USER=hospo_ops_user
DB_PASSWORD=changeme_strong_password
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@db:5432/hospo_ops

# NextAuth
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000

# App
APP_NAME=HOSPO OPS
APP_URL=http://localhost:3000
DEFAULT_TIMEZONE=Pacific/Auckland

# Worker session
WORKER_SESSION_SECRET=generate_separate_secret
WORKER_SESSION_EXPIRY_MINUTES=15

# File uploads (Phase 1: local disk, Phase 2: S3)
UPLOAD_PROVIDER=local
UPLOAD_PATH=/app/uploads
